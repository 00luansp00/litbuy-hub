# Real staging template. Copy outside Git and replace every placeholder. This file is not sufficient to start until a real external email/SMS implementation is configured.
NODE_ENV=staging
PORT=3001
API_PREFIX=api/v1
DATABASE_URL=postgresql://litbuy_staging:<replace-with-staging-password>@postgres:5432/litbuy_staging?schema=public
REDIS_URL=redis://redis:6379
CORS_ORIGINS=https://frontend-staging.example.test
PUBLIC_FRONTEND_ORIGIN=https://frontend-staging.example.test
PUBLIC_API_ORIGIN=https://api-staging.example.test
AUTH_COOKIE_TOPOLOGY=same-site-subdomains
LOG_LEVEL=info
SWAGGER_ENABLED=false
TRUST_PROXY=1
SERVER_REQUEST_TIMEOUT_MS=60000
AUTH_ACCESS_TOKEN_SECRET=<replace-with-64-random-chars>
AUTH_ACCESS_TOKEN_TTL_SECONDS=600
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_TOKEN_PEPPER=<replace-with-64-random-chars>
AUTH_VERIFICATION_TOKEN_PEPPER=<replace-with-64-random-chars>
AUTH_DEVICE_TOKEN_PEPPER=<replace-with-64-random-chars>
AUTH_CSRF_TOKEN_PEPPER=<replace-with-64-random-chars>
AUTH_IP_HASH_PEPPER=<replace-with-64-random-chars>
AUTH_2FA_RECOVERY_PEPPER=<replace-with-64-random-chars>
AUTH_STEP_UP_TOKEN_PEPPER=<replace-with-64-random-chars>
AUTH_REFRESH_COOKIE_NAME=litbuy_refresh
AUTH_DEVICE_COOKIE_NAME=litbuy_device
AUTH_CSRF_COOKIE_NAME=litbuy_csrf
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=example.test
AUTH_EMAIL_DELIVERY_MODE=external
AUTH_SMS_DELIVERY_MODE=external
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=30
AUTH_DEVICE_APPROVAL_TTL_MINUTES=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_PHONE_VERIFICATION_TTL_MINUTES=10
AUTH_PHONE_RESEND_COOLDOWN_SECONDS=60
AUTH_EMAIL_CHANGE_TTL_MINUTES=30
AUTH_SENSITIVE_CHANGE_HOLD_HOURS=48
AUTH_2FA_CODE_TTL_MINUTES=10
AUTH_2FA_RESEND_COOLDOWN_SECONDS=60
AUTH_2FA_MAX_ATTEMPTS=5
AUTH_2FA_RECOVERY_CODE_COUNT=10
AUTH_STEP_UP_GRANT_TTL_MINUTES=10
AUTH_STEP_UP_RESEND_COOLDOWN_SECONDS=60
AUTH_STEP_UP_MAX_ATTEMPTS=5
CURRENT_TERMS_VERSION=2026-07-14
CURRENT_PRIVACY_VERSION=2026-07-14
CURRENT_SELLER_AGREEMENT_VERSION=2026-07
# External auth delivery - fill from secret manager only, never commit real values
AUTH_EMAIL_PROVIDER=resend
RESEND_API_KEY=<set-in-secret-manager>
RESEND_FROM_EMAIL=<verified-auth-sender>
RESEND_FROM_NAME=LIT Buy
RESEND_REPLY_TO=
AUTH_SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=<set-in-secret-manager>
TWILIO_AUTH_TOKEN=<set-in-secret-manager>
TWILIO_MESSAGING_SERVICE_SID=<set-one-sender-strategy>
TWILIO_FROM_NUMBER=
AUTH_EXTERNAL_DELIVERY_TIMEOUT_MS=5000
