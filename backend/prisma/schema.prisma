generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_EMAIL
  ACTIVE
  SUSPENDED
  DELETION_PENDING
  DELETED
}

enum DeviceStatus {
  PENDING
  APPROVED
  REVOKED
}

enum VerificationPurpose {
  EMAIL_VERIFICATION
  DEVICE_APPROVAL
  PASSWORD_RESET
  PHONE_VERIFICATION
  EMAIL_CHANGE_CURRENT
  EMAIL_CHANGE_NEW
  TWO_FACTOR_ENROLLMENT
  TWO_FACTOR_LOGIN
  TWO_FACTOR_DISABLE
  TWO_FACTOR_STEP_UP
  TWO_FACTOR_METHOD_CHANGE
}

enum TwoFactorMethod {
  EMAIL
  SMS
}

enum PlatformRole {
  BUYER
  SELLER
  ADMIN
}

enum SellerApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum SellerProfileStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum SecurityEventType {
  REGISTERED
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFIED
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGIN_LOCKED
  DEVICE_APPROVAL_REQUIRED
  DEVICE_APPROVAL_REQUESTED
  DEVICE_APPROVED
  SESSION_CREATED
  SESSION_REFRESHED
  REFRESH_TOKEN_REUSE_DETECTED
  SESSION_REVOKED
  LOGOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED
  LOGOUT_ALL
  DEVICE_REVOKED
  PHONE_VERIFICATION_REQUESTED
  PHONE_VERIFIED
  PHONE_CHANGED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CURRENT_CONFIRMED
  EMAIL_CHANGE_NEW_CONFIRMED
  EMAIL_CHANGED
  SENSITIVE_ACTION_HOLD_STARTED
  TWO_FACTOR_ENROLLMENT_REQUESTED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_LOGIN_REQUIRED
  TWO_FACTOR_LOGIN_SUCCEEDED
  TWO_FACTOR_LOGIN_FAILED
  TWO_FACTOR_RECOVERY_CODE_USED
  TWO_FACTOR_DISABLE_REQUESTED
  TWO_FACTOR_DISABLED
  STEP_UP_REQUESTED
  STEP_UP_SUCCEEDED
  STEP_UP_FAILED
  STEP_UP_GRANT_CONSUMED
  TWO_FACTOR_METHOD_CHANGE_REQUESTED
  TWO_FACTOR_METHOD_CHANGED
  TWO_FACTOR_RECOVERY_CODES_REGENERATED
  ROLE_GRANTED
  ROLE_REVOKED
  SELLER_APPLICATION_DRAFT_SAVED
  SELLER_APPLICATION_SUBMITTED
  SELLER_APPLICATION_REVIEW_STARTED
  SELLER_APPLICATION_APPROVED
  SELLER_APPLICATION_REJECTED
  SELLER_PROFILE_CREATED
  CATALOG_CATEGORY_CREATED
  CATALOG_CATEGORY_UPDATED
  CATALOG_CATEGORY_STATUS_CHANGED
  CATALOG_SUBCATEGORY_CREATED
  CATALOG_SUBCATEGORY_UPDATED
  CATALOG_SUBCATEGORY_STATUS_CHANGED
  CATALOG_ATTRIBUTE_CREATED
  CATALOG_ATTRIBUTE_UPDATED
  CATALOG_ATTRIBUTE_STATUS_CHANGED
}

enum StepUpScope {
  TWO_FACTOR_METHOD_CHANGE
  TWO_FACTOR_RECOVERY_REGENERATE
}

enum StepUpAssurance {
  TWO_FACTOR
  RECOVERY_CODE
}

enum SecurityEventOutcome {
  SUCCESS
  FAILURE
  BLOCKED
  PENDING
  CRITICAL
}

model User {
  id                         String                  @id @default(uuid()) @db.Uuid
  email                      String                  @unique
  phoneE164                  String?
  phoneVerifiedAt            DateTime?
  birthDate                  DateTime                @db.Date
  status                     UserStatus              @default(PENDING_EMAIL)
  emailVerifiedAt            DateTime?
  termsVersion               String
  termsAcceptedAt            DateTime
  privacyVersion             String
  privacyAcceptedAt          DateTime
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  deletedAt                  DateTime?
  sensitiveActionHoldUntil   DateTime?
  lastSensitiveChangeAt      DateTime?
  passwordCredential         PasswordCredential?
  devices                    Device[]
  sessions                   Session[]
  verificationChallenges     VerificationChallenge[]
  securityEvents             SecurityEvent[]
  emailChangeRequests        EmailChangeRequest[]
  twoFactorSettings          TwoFactorSettings?
  twoFactorRecoveryCodes     TwoFactorRecoveryCode[]
  stepUpGrants               StepUpGrant[]
  roleAssignments            UserRoleAssignment[]
  sellerApplication          SellerApplication?      @relation("SellerApplicationOwner")
  reviewedSellerApplications SellerApplication[]     @relation("SellerApplicationReviewer")
  sellerProfile              SellerProfile?

  @@unique([phoneE164])
  @@index([email])
  @@index([status])
}

model UserRoleAssignment {
  userId    String       @db.Uuid
  role      PlatformRole
  grantedAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role])
}

model SellerApplication {
  id                        String                  @id @default(uuid()) @db.Uuid
  userId                    String                  @unique @db.Uuid
  storeName                 String
  requestedSlug             String
  description               String?
  status                    SellerApplicationStatus @default(DRAFT)
  sellerAgreementVersion    String?
  sellerAgreementAcceptedAt DateTime?
  submittedAt               DateTime?
  reviewedAt                DateTime?
  reviewedByUserId          String?                 @db.Uuid
  rejectionCode             String?
  rejectionReason           String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  user       User  @relation("SellerApplicationOwner", fields: [userId], references: [id], onDelete: Restrict)
  reviewedBy User? @relation("SellerApplicationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, submittedAt])
  @@index([requestedSlug])
}

model SellerProfile {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @unique @db.Uuid
  storeName   String
  slug        String              @unique
  description String?
  status      SellerProfileStatus @default(ACTIVE)
  verified    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([slug])
}

model PasswordCredential {
  userId              String    @id @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  passwordHash        String
  passwordChangedAt   DateTime  @default(now())
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Device {
  id                     String                  @id @default(uuid()) @db.Uuid
  userId                 String                  @db.Uuid
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  tokenHash              String                  @unique
  displayName            String?
  userAgent              String?
  status                 DeviceStatus            @default(PENDING)
  isInitialDevice        Boolean                 @default(false)
  approvedAt             DateTime?
  firstSeenAt            DateTime                @default(now())
  lastSeenAt             DateTime                @default(now())
  revokedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  sessions               Session[]
  verificationChallenges VerificationChallenge[]
  securityEvents         SecurityEvent[]
  stepUpGrants           StepUpGrant[]

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, status])
}

model Session {
  id                   String                @id @default(uuid()) @db.Uuid
  userId               String                @db.Uuid
  deviceId             String                @db.Uuid
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  device               Device                @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  refreshTokenHash     String                @unique
  refreshTokenFamilyId String                @db.Uuid
  csrfTokenHash        String
  expiresAt            DateTime
  lastUsedAt           DateTime              @default(now())
  revokedAt            DateTime?
  revocationReason     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  securityEvents       SecurityEvent[]
  refreshTokens        SessionRefreshToken[]
  stepUpGrants         StepUpGrant[]

  @@index([userId])
  @@index([deviceId])
  @@index([refreshTokenHash])
  @@index([refreshTokenFamilyId])
  @@index([revokedAt, expiresAt])
}

model VerificationChallenge {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  deviceId    String?             @db.Uuid
  user        User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  device      Device?             @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  purpose     VerificationPurpose
  tokenHash   String              @unique
  targetHash  String?
  contextId   String?             @db.Uuid
  attempts    Int                 @default(0)
  maxAttempts Int
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime            @default(now())

  @@index([userId])
  @@index([deviceId])
  @@index([purpose])
  @@index([targetHash])
  @@index([contextId])
  @@index([purpose, consumedAt, expiresAt])
}

model EmailChangeRequest {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @db.Uuid
  user                    User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  newEmailHash            String
  expiresAt               DateTime
  currentEmailConfirmedAt DateTime?
  newEmailConfirmedAt     DateTime?
  completedAt             DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId])
  @@index([newEmailHash])
  @@index([completedAt, cancelledAt, expiresAt])
}

model SecurityEvent {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String?              @db.Uuid
  sessionId String?              @db.Uuid
  deviceId  String?              @db.Uuid
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  session   Session?             @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  device    Device?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  eventType SecurityEventType
  outcome   SecurityEventOutcome
  metadata  Json                 @default("{}")
  ipHash    String?
  userAgent String?
  createdAt DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model SessionRefreshToken {
  id                String                @id @default(uuid()) @db.Uuid
  sessionId         String                @db.Uuid
  familyId          String                @db.Uuid
  session           Session               @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  tokenHash         String                @unique
  expiresAt         DateTime
  issuedAt          DateTime              @default(now())
  usedAt            DateTime?
  revokedAt         DateTime?
  replacedByTokenId String?               @db.Uuid
  replacedByToken   SessionRefreshToken?  @relation("RefreshReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replaces          SessionRefreshToken[] @relation("RefreshReplacement")
  createdAt         DateTime              @default(now())

  @@index([sessionId])
  @@index([familyId])
  @@index([tokenHash])
  @@index([familyId, revokedAt, expiresAt])
}

model TwoFactorSettings {
  userId     String          @id @db.Uuid
  user       User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  method     TwoFactorMethod
  enabledAt  DateTime
  disabledAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([disabledAt])
}

model TwoFactorRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, usedAt])
}

model StepUpGrant {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  sessionId  String          @db.Uuid
  deviceId   String          @db.Uuid
  scope      StepUpScope
  assurance  StepUpAssurance
  tokenHash  String          @unique
  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  session    Session         @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  device     Device          @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([sessionId, scope])
  @@index([deviceId])
  @@index([tokenHash])
  @@index([expiresAt, consumedAt, revokedAt])
}

enum CatalogEntityStatus {
  ACTIVE
  INACTIVE
}

enum CatalogProductType {
  ACCOUNT
  VIRTUAL_CURRENCY
  GIFT_CARD
  KEY
  SKIN
  ITEM
  SERVICE
  SUBSCRIPTION
  GAME
  SOFTWARE
  OTHER
}

enum CatalogAttributeInputType {
  TEXT
  NUMBER
  SELECT
  BOOLEAN
}

model CatalogCategory {
  id          String              @id @default(uuid()) @db.Uuid
  slug        String              @unique
  name        String
  description String?
  iconKey     String?
  colorHex    String?
  sortOrder   Int                 @default(0)
  featured    Boolean             @default(false)
  status      CatalogEntityStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  subcategories CatalogSubcategory[]

  @@index([status, sortOrder])
  @@index([featured, status, sortOrder])
}

model CatalogSubcategory {
  id         String              @id @default(uuid()) @db.Uuid
  categoryId String              @db.Uuid
  slug       String
  name       String
  sortOrder  Int                 @default(0)
  status     CatalogEntityStatus @default(ACTIVE)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  category   CatalogCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attributes CatalogAttribute[]

  @@unique([categoryId, slug])
  @@index([categoryId, status, sortOrder])
}

model CatalogAttribute {
  id            String                    @id @default(uuid()) @db.Uuid
  subcategoryId String?                   @db.Uuid
  productType   CatalogProductType?
  key           String
  label         String
  inputType     CatalogAttributeInputType
  placeholder   String?
  required      Boolean                   @default(false)
  selectOptions String[]                  @default([])
  sortOrder     Int                       @default(0)
  status        CatalogEntityStatus       @default(ACTIVE)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  subcategory CatalogSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@index([subcategoryId, status, sortOrder])
  @@index([productType, status, sortOrder])
}
