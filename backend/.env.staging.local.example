# Local staging rehearsal only. Not for public staging or production. Uses NODE_ENV=test so memory providers are confined to isolated local/CI checks.
NODE_ENV=test
PORT=3001
API_PREFIX=api/v1
DATABASE_URL=postgresql://litbuy:litbuy_local_staging_password_not_for_production@postgres:5432/litbuy_staging_local?schema=public
REDIS_URL=redis://redis:6379
CORS_ORIGINS=http://localhost:3000
PUBLIC_FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_API_ORIGIN=http://localhost:3001
AUTH_COOKIE_TOPOLOGY=same-origin
LOG_LEVEL=info
SWAGGER_ENABLED=false
TRUST_PROXY=false
SERVER_REQUEST_TIMEOUT_MS=60000
AUTH_ACCESS_TOKEN_SECRET=local_staging_rehearsal_access_secret_32_chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=600
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_TOKEN_PEPPER=local_staging_rehearsal_refresh_pepper_32_chars
AUTH_VERIFICATION_TOKEN_PEPPER=local_staging_rehearsal_verification_pepper_32_chars
AUTH_DEVICE_TOKEN_PEPPER=local_staging_rehearsal_device_pepper_32_chars
AUTH_CSRF_TOKEN_PEPPER=local_staging_rehearsal_csrf_pepper_32_chars
AUTH_IP_HASH_PEPPER=local_staging_rehearsal_ip_hash_pepper_32_chars
AUTH_2FA_RECOVERY_PEPPER=local_staging_rehearsal_2fa_recovery_32_chars
AUTH_STEP_UP_TOKEN_PEPPER=local_staging_rehearsal_step_up_pepper_32_chars
AUTH_REFRESH_COOKIE_NAME=litbuy_refresh
AUTH_DEVICE_COOKIE_NAME=litbuy_device
AUTH_CSRF_COOKIE_NAME=litbuy_csrf
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_EMAIL_DELIVERY_MODE=memory
AUTH_SMS_DELIVERY_MODE=memory
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=30
AUTH_DEVICE_APPROVAL_TTL_MINUTES=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_PHONE_VERIFICATION_TTL_MINUTES=10
AUTH_PHONE_RESEND_COOLDOWN_SECONDS=60
AUTH_EMAIL_CHANGE_TTL_MINUTES=30
AUTH_SENSITIVE_CHANGE_HOLD_HOURS=48
AUTH_2FA_CODE_TTL_MINUTES=10
AUTH_2FA_RESEND_COOLDOWN_SECONDS=60
AUTH_2FA_MAX_ATTEMPTS=5
AUTH_2FA_RECOVERY_CODE_COUNT=10
AUTH_STEP_UP_GRANT_TTL_MINUTES=10
AUTH_STEP_UP_RESEND_COOLDOWN_SECONDS=60
AUTH_STEP_UP_MAX_ATTEMPTS=5
CURRENT_TERMS_VERSION=2026-07-14
CURRENT_PRIVACY_VERSION=2026-07-14
